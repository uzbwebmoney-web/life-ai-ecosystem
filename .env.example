BOT_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# SQLite по умолчанию (работает сразу). Для PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/life_ai
# SQLite (локально):
# DATABASE_URL=sqlite+aiosqlite:///./life_ai.db
# SQLite (Docker — volume ./data):
DATABASE_URL=sqlite+aiosqlite:///./data/life_ai.db

DEFAULT_LANGUAGE=ru
