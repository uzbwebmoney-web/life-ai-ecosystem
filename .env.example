BOT_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Image generation (gpt-image-1; quality by plan: Basic=Low, Premium=Medium, Pro=High)
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_MODEL_FALLBACKS=dall-e-2
ADVANCED_OPENAI_MODEL=gpt-5.4-mini
PRO_OPENAI_MODEL=gpt-5.5

# SQLite по умолчанию (работает сразу). Для PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/life_ai
# SQLite (локально):
# DATABASE_URL=sqlite+aiosqlite:///./life_ai.db
# SQLite (Docker — volume ./data):
DATABASE_URL=sqlite+aiosqlite:///./data/life_ai.db

DEFAULT_LANGUAGE=ru

# Admin in bot: /admin (your Telegram user id from @userinfobot)
ADMIN_TELEGRAM_IDS=123456789
ADMIN_NEW_USER_NOTIFY=true
ADMIN_AI_REQUEST_NOTIFY=true

# Web search for актуальные контакты, ссылки, правила (OpenAI Responses + fallback)
WEB_SEARCH_ENABLED=true
WEB_SEARCH_ALL_MODULES=true

# Subscription payments (card transfer + admin confirmation)
PAYMENT_CARD_NUMBER=8600123456789012
PAYMENT_CARD_HOLDER=IVAN IVANOV
PAYMENT_CONTACT=@your_support
